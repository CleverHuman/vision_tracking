# Database
DATABASE_URL="postgresql://postgres:123456@localhost:5432/vision_tracking?schema=public"

# JWT
JWT_SECRET="your-jwt-secret-key-change-in-production"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-key-change-in-production"

# AWS S3
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"
S3_BUCKET_NAME="vision-tracking-assets"

# Storage Provider ("s3" or "gdrive", defaults to "s3")
STORAGE_PROVIDER="s3"

# Google Drive (required when STORAGE_PROVIDER="gdrive")
# Run "npx ts-node scripts/gdrive-auth.ts" to get GOOGLE_REFRESH_TOKEN
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/auth/google/callback"
GOOGLE_REFRESH_TOKEN=""
GDRIVE_FOLDER_ID=""

# Vision Server
VISION_SERVER_URL="http://vision_server:8000"
VISION_API_KEY="your-vision-api-key"

# Internal
INTERNAL_WEBHOOK_SECRET="your-internal-webhook-secret"

# Server
PORT=3000
NODE_ENV="development"
FRONTEND_URL="http://localhost:5173"

# SMTP (email)
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=587
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-pass"
